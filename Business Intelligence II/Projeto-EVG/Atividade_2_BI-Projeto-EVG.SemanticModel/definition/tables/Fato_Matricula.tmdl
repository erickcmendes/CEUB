table Fato_Matricula
	lineageTag: 587e2051-bd09-4867-99b0-9143564b118d

	measure 'Total Matriculas' =
			
			COUNTROWS(Fato_Matricula)
		formatString: 0
		lineageTag: d808cffb-b6eb-4299-8faa-3f3a5277542a

	measure 'Matriculas Concluidas' =
			
			CALCULATE(
			    [Total Matriculas],
			    Fato_Matricula[sit_matricula] = "Concluida"
			)
		formatString: 0
		lineageTag: 4a679541-75e0-474b-8ae9-9f38fecf0dac

	measure 'Taxa de Conclusao' =
			
			DIVIDE(
			    [Matriculas Concluidas],
			    [Total Matriculas],
			    0
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b79ce0b3-23f7-4ded-ae19-9708720fc0af

	measure 'Horas de Capacitação' = ```
			
			CALCULATE(
			    SUMX(
			        Fato_Matricula, 
			        RELATED(Dim_Curso[carga_horaria])
			    ),
			    Fato_Matricula[sit_matricula] = "Concluida"
			)
			```
		formatString: 0
		lineageTag: 9f79aab3-0bbc-46f2-8dae-2bee0242c0f9

	measure 'Total Evasoes' = ```
			
			CALCULATE(
			    [Total Matriculas],
			    Fato_Matricula[sit_matricula] = "Reprovado" 
			)
			```
		formatString: 0
		lineageTag: f0193b2b-a430-435c-8b5f-d90f3d9b1549

	measure 'Curso Maior Evasao' = ```
			
			VAR vTopCurso = 
			    TOPN(
			        1, 
			        ALL(Dim_Curso[nome_curso]), 
			        [Total Evasoes], 
			        DESC
			    )
			
			RETURN
			    CALCULATE(
			        SELECTEDVALUE(Dim_Curso[nome_curso]),
			        vTopCurso
			    )
			```
		lineageTag: d464084f-3643-41b2-9b2e-abbafaeb70f3

	column cod_matricula
		dataType: string
		lineageTag: 025f1bd8-5bcc-4590-ae36-03ce3a877282
		summarizeBy: none
		sourceColumn: cod_matricula

		annotation SummarizationSetBy = Automatic

